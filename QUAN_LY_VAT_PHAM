    private void btnXoaActionPerformed(java.awt.event.ActionEvent evt) {                                       
         if (idVatPham == -1) {

        JOptionPane.showMessageDialog(
                this,
                "Vui lòng chọn vật phẩm cần xóa"
        );

        return;
    }

    int chon = JOptionPane.showConfirmDialog(
            this,
            "Bạn có chắc muốn xóa không?",
            "Xác nhận",
            JOptionPane.YES_NO_OPTION
    );

    if (chon == JOptionPane.YES_OPTION) {

        VatPhamDAO dao = new VatPhamDAO();

        if (dao.xoaVatPham(idVatPham)) {

            JOptionPane.showMessageDialog(
                    this,
                    "Xóa thành công"
            );

            loadTable();

            txtTenVatPham.setText("");
            txtDonGia.setText("");
            cboTrangThai.setSelectedIndex(0);

            idVatPham = -1;

        } else {

            JOptionPane.showMessageDialog(
                    this,
                    "Xóa thất bại"
            );
        }
    }
    }                                      

    private void btnSuaActionPerformed(java.awt.event.ActionEvent evt) {                                       
        if (idVatPham == -1) {

        JOptionPane.showMessageDialog(
                this,
                "Vui lòng chọn vật phẩm cần sửa"
        );

        return;
    }

    try {

        VatPham vp = new VatPham();

        vp.setIdVatPham(idVatPham);

        vp.setTenVatPham(
                txtTenVatPham.getText());

        vp.setDonGia(
                Double.parseDouble(
                        txtDonGia.getText()));

        vp.setTrangThaiVatPham(
                cboTrangThai.getSelectedItem().toString());

        VatPhamDAO dao = new VatPhamDAO();

        if (dao.suaVatPham(vp)) {

            JOptionPane.showMessageDialog(
                    this,
                    "Sửa thành công"
            );

            loadTable();

        } else {

            JOptionPane.showMessageDialog(
                    this,
                    "Sửa thất bại"
            );
        }

        } catch (Exception e) {

            e.printStackTrace();
        }
    }                                      

    private void btnLamMoiActionPerformed(java.awt.event.ActionEvent evt) {                                          
        txtTenVatPham.setText("");

    txtDonGia.setText("");

    cboTrangThai.setSelectedIndex(0);

    tblVatPham.clearSelection();

    idVatPham = -1;
}                                         

    private void btnThemActionPerformed(java.awt.event.ActionEvent evt) {                                        
        try {

            String ten = txtTenVatPham.getText();

            double gia =
                    Double.parseDouble(
                            txtDonGia.getText());

            String trangThai =
                    cboTrangThai.getSelectedItem().toString();

            VatPham vp = new VatPham();

            vp.setTenVatPham(ten);
            vp.setDonGia(gia);
            vp.setTrangThaiVatPham(trangThai);

            VatPhamDAO dao = new VatPhamDAO();

            if (dao.themVatPham(vp)) {

                JOptionPane.showMessageDialog(
                        this,
                        "Thêm thành công"
                );

                loadTable();

            } else {

                JOptionPane.showMessageDialog(
                        this,
                        "Thêm thất bại"
               );
           }
       } catch (Exception e) {

            JOptionPane.showMessageDialog(
                    this,
                    "Dữ liệu không hợp lệ"
            );
        }
    }                                       

