    public void loadTable() {

        DefaultTableModel model =
                (DefaultTableModel) tblVatPham.getModel();

        model.setRowCount(0);

        VatPhamDAO dao = new VatPhamDAO();

        ArrayList<VatPham> list =
                dao.getAll();

        for (VatPham vp : list) {

            model.addRow(new Object[]{
                vp.getIdVatPham(),
                vp.getTenVatPham(),
                vp.getDonGia(),
                vp.getTrangThaiVatPham()
            });
        }
    }

