    private void tblVatPhamMouseClicked(java.awt.event.MouseEvent evt) {                                        
        int row = tblVatPham.getSelectedRow();
        
        idVatPham = Integer.parseInt(
            tblVatPham.getValueAt(row, 0).toString());

        txtTenVatPham.setText(
                tblVatPham.getValueAt(row, 1).toString());

        txtDonGia.setText(
                tblVatPham.getValueAt(row, 2).toString());

        cboTrangThai.setSelectedItem(
                tblVatPham.getValueAt(row, 3).toString());
    }                                       

