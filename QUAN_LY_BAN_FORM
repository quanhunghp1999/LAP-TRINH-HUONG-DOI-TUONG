    private void loadTable() {

    DefaultTableModel model =
            (DefaultTableModel) tblBan.getModel();

    model.setRowCount(0);

    BanDAO dao = new BanDAO();

    for (Ban b : dao.getAll()) {

        model.addRow(new Object[]{
            b.getIdBan(),
            b.getTrangThaiBan()
        });
    }
}

