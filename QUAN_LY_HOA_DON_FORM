    private void btnSuaActionPerformed(java.awt.event.ActionEvent evt) {                                       
            try {

    if (idHoaDon == -1) {
        JOptionPane.showMessageDialog(this, "Chọn hóa đơn để sửa");
        return;
    }

    HoaDon hd = new HoaDon();

    hd.setIdHoaDon(idHoaDon);
    hd.setTongTien(Double.parseDouble(txtTongTien.getText()));
    hd.setPhuongThucThanhToan(txtPhuongThuc.getText());
    hd.setIdUser(Integer.parseInt(cboUser.getSelectedItem().toString()));
    hd.setIdVoucher(Integer.parseInt(cboVoucher.getSelectedItem().toString()));

    HoaDonDAO dao = new HoaDonDAO();

    if (dao.suaHoaDon(hd)) {
        JOptionPane.showMessageDialog(this, "Sửa thành công");
        loadTable();
        resetForm();
        idHoaDon = -1;
    } else {
        JOptionPane.showMessageDialog(this, "Sửa thất bại");
    }

} catch (Exception e) {
    e.printStackTrace();
    JOptionPane.showMessageDialog(this, "Lỗi sửa hóa đơn");
}
    }                                      

    private void tblHoaDonMouseClicked(java.awt.event.MouseEvent evt) {                                       
         int row = tblHoaDon.getSelectedRow();
idHoaDon = Integer.parseInt(tblHoaDon.getValueAt(row, 0).toString());

            txtTongTien.setText(tblHoaDon.getValueAt(row, 1).toString());
            txtPhuongThuc.setText(tblHoaDon.getValueAt(row, 2).toString());

            cboUser.setSelectedItem(tblHoaDon.getValueAt(row, 3).toString());
            cboVoucher.setSelectedItem(tblHoaDon.getValueAt(row, 4).toString());
    }                                      

    private void btnThemActionPerformed(java.awt.event.ActionEvent evt) {                                        
       try {

            HoaDon hd = new HoaDon();

            hd.setTongTien(Double.parseDouble(txtTongTien.getText().trim()));
            hd.setPhuongThucThanhToan(txtPhuongThuc.getText().trim());
            hd.setIdUser(Integer.parseInt(cboUser.getSelectedItem().toString()));
            hd.setIdVoucher(Integer.parseInt(cboVoucher.getSelectedItem().toString()));

            HoaDonDAO dao = new HoaDonDAO();

            if (dao.themHoaDon(hd)) {
                JOptionPane.showMessageDialog(this, "Thêm thành công");

                loadTable();
                resetForm();
            } else {
                JOptionPane.showMessageDialog(this, "Thêm thất bại");
            }

        } catch (Exception e) {
            e.printStackTrace();
            JOptionPane.showMessageDialog(this, "Lỗi thêm hóa đơn");
        }
    }                                       

    private void btnXoaActionPerformed(java.awt.event.ActionEvent evt) {                                       
         try {

        if (idHoaDon == -1) {
            JOptionPane.showMessageDialog(this, "Chọn hóa đơn để xoá");
            return;
        }

        int confirm = JOptionPane.showConfirmDialog(
                this,
                "Bạn có chắc muốn xoá?",
                "Confirm",
                JOptionPane.YES_NO_OPTION
        );

        if (confirm == JOptionPane.YES_OPTION) {

            HoaDonDAO dao = new HoaDonDAO();

            if (dao.xoaHoaDon(idHoaDon)) {
                JOptionPane.showMessageDialog(this, "Xoá thành công");

                loadTable();
                resetForm();
                idHoaDon = -1;
            } else {
                JOptionPane.showMessageDialog(this, "Xoá thất bại");
            }
        }

    } catch (Exception e) {
        e.printStackTrace();
        JOptionPane.showMessageDialog(this, "Lỗi xoá hóa đơn");
    }
    }                                      

