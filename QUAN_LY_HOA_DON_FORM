    private void loadTable() {

        DefaultTableModel model = (DefaultTableModel) tblHoaDon.getModel();
        model.setRowCount(0);

        HoaDonDAO dao = new HoaDonDAO();

        for (HoaDon hd : dao.getAll()) {
            model.addRow(new Object[]{
                hd.getIdHoaDon(),
                hd.getTongTien(),
                hd.getPhuongThucThanhToan(),
                hd.getIdUser(),
                hd.getIdVoucher()
            });
        }
    }

    private void resetForm() {

        txtTongTien.setText("");
        txtPhuongThuc.setText("");

        cboUser.setSelectedIndex(0);
        cboVoucher.setSelectedIndex(0);

        idHoaDon = -1;
    }

    private void loadUserCombo() {

        cboUser.removeAllItems();

        UserDAO dao = new UserDAO();

        for (User u : dao.getAll()) {
            cboUser.addItem(String.valueOf(u.getIdUser()));
        }
    }

    private void loadVoucherCombo() {

        cboVoucher.removeAllItems();

        VoucherDAO dao = new VoucherDAO();

        for (Voucher v : dao.getAll()) {
            cboVoucher.addItem(String.valueOf(v.getIdVoucher()));
        }
    }
